# Будет считан docker-compose'ом и приложением.

# Telegram
TELEGRAM_BOT_TOKEN=

# Postgres (используется и контейнером postgres, и нашим API)
POSTGRES_USER=academ
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=academ
# Внутри docker-compose сети хост — это имя сервиса (postgres)
DATABASE_URL=postgresql://academ:change_me_strong_password@postgres:5432/academ

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=

# CORS
CORS_ORIGINS=https://academ-voice.vercel.app,http://localhost:5173

# Домен для Caddy (без https://). Например: api.academvoice.ru
API_DOMAIN=
