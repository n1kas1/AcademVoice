# Скопируй в .env на VPS и заполни значения.

# Telegram — токен из @BotFather (новый, после /revoke!)
TELEGRAM_BOT_TOKEN=

# Supabase Postgres (Project Settings → Database → Connection string → URI, Mode=Session)
# Пример:
# postgresql://postgres.xxxxx:PASS@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# LiveKit Cloud (cloud.livekit.io → Settings → API Keys)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=

# Откуда стучится фронт. После Vercel-деплоя добавь Vercel-домен.
CORS_ORIGINS=https://academ-voice.vercel.app,http://localhost:5173

# Домен бэка (A-запись на IP Kamatera VPS). Без https://.
API_DOMAIN=
