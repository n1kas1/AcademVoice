# Caddy: фронт-статика на / + проксирование API-эндпоинтов на сервис api.
# Домен берётся из env API_DOMAIN (см. docker-compose).
# При первом запуске Caddy сам получит Let's Encrypt сертификат.

{$API_DOMAIN} {
    encode zstd gzip

    # Эндпоинты бэка — проксируем по их реальным путям без перепрефикса.
    @api path /me /match/* /call/* /health
    handle @api {
        reverse_proxy api:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Всё остальное — SPA-фронт.
    handle {
        root * /srv
        encode zstd gzip
        try_files {path} /index.html
        file_server
    }
}
